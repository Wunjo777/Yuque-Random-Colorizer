{
  "manifest_version": 3,
  "name": "Yuque 画板随机着色",
  "version": "1.0.0",
  "description": "在语雀画板中对元素自动随机着色，支持色彩梯度和候选颜色",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.yuque.com/*"
  ]
}
